{
  "manifest_version": 2,
  "name": "AMASAMYA — Accessibility Audit Tool",
  "version": "2.0.0",
  "description": "Blind-first accessibility audit tool. 13 WCAG 2.2 audit engines with accessible sidebar results. Built by Akhilesh Malani.",
  "author": "Akhilesh Malani",
  "homepage_url": "https://amasamya.akhileshmalani.com",

  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],

  "browser_action": {
    "default_title": "Run AMASAMYA Audit (Ctrl+Shift+U)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "sidebar_action": {
    "default_title": "AMASAMYA Audit Results",
    "default_panel": "sidebar/panel.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },

  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "windows": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Run AMASAMYA accessibility audit on the current page"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["https://amasamya.akhileshmalani.com/*"],
      "js": ["content-script-platform.js"],
      "run_at": "document_idle"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "AMASAMYA@akhileshmalani.com",
      "strict_min_version": "109.0"
    }
  }
}
