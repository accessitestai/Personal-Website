{
  "manifest_version": 2,
  "name": "AMA11Y — Accessibility Audit Tool",
  "version": "2.0.0",
  "description": "Blind-first accessibility audit tool. 13 WCAG 2.2 audit engines with accessible sidebar results. Built by Akhilesh Malani.",
  "author": "Akhilesh Malani",
  "homepage_url": "https://ama11y.akhileshmalani.com",

  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],

  "browser_action": {
    "default_title": "Run AMA11Y Audit (Alt+Shift+A)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "sidebar_action": {
    "default_title": "AMA11Y Audit Results",
    "default_panel": "sidebar/panel.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },

  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "windows": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "Run AMA11Y accessibility audit on the current page"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "background": {
    "scripts": ["background.js"]
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "ama11y@akhileshmalani.com",
      "strict_min_version": "109.0"
    }
  }
}
