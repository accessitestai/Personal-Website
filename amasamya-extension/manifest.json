{
  "manifest_version": 3,
  "name": "AMASAMYA - Accessibility Audit Tool",
  "version": "4.3.1",
  "description": "Blind-first WCAG 2.2 audit tool for any page or a whole site. Diff shows what changed since your last audit.",
  "author": "Akhilesh Malani",
  "homepage_url": "https://amasamya.akhileshmalani.com",
  "minimum_chrome_version": "114",

  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs",
    "storage",
    "debugger"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_title": "Run AMASAMYA Audit (Alt+Shift+1). You can change the shortcut at chrome://extensions/shortcuts.",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default":  "Alt+Shift+1",
        "windows":  "Alt+Shift+1",
        "linux":    "Alt+Shift+1",
        "chromeos": "Alt+Shift+1",
        "mac":      "Alt+Shift+1"
      },
      "description": "Run AMASAMYA accessibility audit on the current page"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://amasamya.akhileshmalani.com/*"],
      "js": ["content-script-platform.js"],
      "run_at": "document_idle"
    }
  ]
}
