{
  "manifest_version": 3,
  "name": "AMA11Y — Accessibility Audit Tool",
  "version": "2.0.0",
  "description": "Blind-first accessibility audit tool. 13 WCAG 2.2 audit engines with accessible side panel results. Built by Akhilesh Malani.",
  "author": "Akhilesh Malani",
  "homepage_url": "https://ama11y.akhileshmalani.com",

  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs",
    "storage"
  ],

  "action": {
    "default_title": "Run AMA11Y Audit (Ctrl+Shift+U)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "windows": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Run AMA11Y accessibility audit on the current page"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://ama11y.akhileshmalani.com/*"],
      "js": ["content-script-platform.js"],
      "run_at": "document_idle"
    }
  ]
}
