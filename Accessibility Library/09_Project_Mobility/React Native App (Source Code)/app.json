{
  "expo": {
    "name": "Mobility Assistant",
    "slug": "mobility-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobility-assistant",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs location access to provide accessible navigation and nearby facility information.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs location access to provide accessible navigation and nearby facility information.",
        "NSMicrophoneUsageDescription": "This app uses the microphone for voice commands and accessibility features."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f3e5eecf-b1f8-4b8d-9ac4-9b1fb5b732a7"
      }
    }
  }
}
